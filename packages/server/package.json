		"elysia": "1.x.x",
		"fumadb": "^0.2.1",
		"hono": "*",
		"mongodb": "6.x.x || 7.x.x",
		"next": "^14.0.0 || ^15.0.0 || ^16.0.0",
		"next-auth": "4.x.x"
	},
