		"@types/node": "^25.6.0",
		"better-auth": "^1.6.9",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.4.28",
		"express": "^5.2.1",
		"fumadb": "^0.2.2",
		"hono": "^4.12.16",
		"mongodb": "^7.2.0",
		"next": "^16.2.4",
		"next-auth": "^4.24.14",
		"tsconfig": "workspace:*",
		"urlpattern-polyfill": "^10.1.0",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
