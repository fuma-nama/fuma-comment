# Database
# PostgreSQL connection string (used by Prisma and @/utils/database)
# Local dev with repo compose.yaml: postgresql://postgres:secret@localhost:5432/fuma_comment
DATABASE_URL=postgresql://postgres:secret@localhost:5432/fuma_comment

# GitHub OAuth (NextAuth — required at startup via zod in app/api/auth/[...nextauth]/options.ts)
# Create an OAuth App: https://github.com/settings/applications/new
# Callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_ID=your_github_client_id_here
GITHUB_SECRET=your_github_client_secret_here

# NextAuth session encryption and base URL (used by next-auth in app/api/auth/[...nextauth]/route.ts)
NEXTAUTH_SECRET=your_random_secret_key_here_min_32_chars
NEXTAUTH_URL=http://localhost:3001

# UploadThing (image uploads on the demo — used by app/api/uploadthing)
UPLOADTHING_TOKEN=your_uploadthing_token_here
